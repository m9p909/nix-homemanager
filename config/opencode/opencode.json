{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/anthropic/claude-sonnet-4-6",
  "small_model": "openrouter/google/gemini-3-flash",
  "enabled_providers": ["openrouter", "moonshotai"],
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "anthropic/claude-sonnet-4-6": {
          "temperature": true
        },
        "google/gemini-3-flash": {
          "temperature": true
        }
      }
    },
    "moonshotai": {
      "models": {
        "kimi-k2.6": {
          "temperature": true
        }
      }
    }
  }
}
